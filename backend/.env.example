# ── Google OAuth ──────────────────────────────────────────────
# Get these from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── LinkedIn OAuth ────────────────────────────────────────────
# Get these from LinkedIn Developer Portal → Auth
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# ── Meta OAuth (Facebook Pages + Instagram Business) ─────────
# Create a Meta app at developers.facebook.com and add:
# Facebook Login, Pages API, and Instagram Graph API products.
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_GRAPH_VERSION=v23.0

# ── App settings ──────────────────────────────────────────────
# The URL where your frontend is running
FRONTEND_URL=http://localhost:5173

# The URL where your backend is running
BACKEND_URL=http://localhost:8000

# Secret key for session signing (generate any random string)
SECRET_KEY=change_this_to_any_random_secret_string

# ── How to get your Google credentials ───────────────────────
# 1. Go to console.cloud.google.com
# 2. Create a project → Enable YouTube Data API v3
# 3. APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 4. Application type: Web Application
# 5. Authorized redirect URIs: http://localhost:8000/auth/callback
# 6. Copy Client ID and Client Secret above

# ── Meta setup notes ──────────────────────────────────────────
# 1. Go to https://developers.facebook.com/apps
# 2. Create a Business app
# 3. Add products: Facebook Login, Pages API, Instagram Graph API
# 4. Add OAuth redirect URI:
#    http://localhost:8000/auth/facebook/callback
# 5. Generate META_APP_ID and META_APP_SECRET and paste them above
# 6. Connect a Facebook Page and an Instagram Business account to the same Meta Business
