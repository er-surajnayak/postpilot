# ── Google OAuth ──────────────────────────────────────────────
# Get these from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── LinkedIn OAuth ────────────────────────────────────────────
# Get these from LinkedIn Developer Portal → Auth
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# ── Meta OAuth (Facebook Pages + Instagram Business) ─────────
# Create a Meta app at developers.facebook.com and add:
# Facebook Login, Pages API, and Instagram Graph API products.
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_GRAPH_VERSION=v23.0

# ── Instagram OAuth (Optional: Instagram Login) ───────────────
# Only needed if you connect Instagram via the "Instagram Login" button, 
# rather than through Meta (Facebook Pages). 
INSTAGRAM_APP_ID=your_instagram_app_id_here
INSTAGRAM_APP_SECRET=your_instagram_app_secret_here

# ── App settings ──────────────────────────────────────────────
# The URL where your frontend is running (e.g. http://localhost:5173 or Vercel URL)
FRONTEND_URL=http://localhost:5173

# The URL where your backend is running (e.g. http://localhost:8000 or Render URL)
BACKEND_URL=http://localhost:8000

# Secret key for session signing (generate any random string)
SECRET_KEY=change_this_to_any_random_secret_string

# ── Setup Notes ───────────────────────────────────────────────
# Google OAuth Callback URI setup:
# Local: http://localhost:8000/auth/callback
# Prod:  https://your-backend-domain/auth/callback

# LinkedIn OAuth Callback URI setup:
# Local: http://localhost:8000/auth/linkedin/callback
# Prod:  https://your-backend-domain/auth/linkedin/callback

# Meta (Facebook Pages + Instagram Business) OAuth Callback URI setup:
# Local: http://localhost:8000/auth/facebook/callback
# Prod:  https://your-backend-domain/auth/facebook/callback
